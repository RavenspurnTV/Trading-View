//A modified Watson Envelope together with a Stochastic D trigger for the entry.
//When the price is inside the 2 Watson Envelopes, and the Stochastic indicates an oversold or overbought
//level, enter a position with a Stoploss using the delta of the upper Envelopes at the upper or lower Envelope.
//The Trailing Stoploss is triggered as a % of the SL distance.

//@version=5
strategy("Rävenspurn Watson Envelope Strategy", overlay=true)

// Input Parameters
// Four Hour SMA (A)
SMA_A_Length = input.int(225, "High Timeframe SMA length", minval=10)                       // SMA line
SMA_A_Signal = input.int(150, "Watson Envelope Smoothing periods", minval=10)               // SMA Signal line

// Slow Stochastic Parameters
SlowStoch_B_length = input.int(15, "15m Slow Stoch Length", minval=1)                       // Slow Stochastic B: Length
SlowStoch_B_sma = input.int(5, "15m Slow Stoch SMA", minval=1)                              // Slow Stochastic B: SMA
SlowStoch_B_slow = input.int(5, "15m Slow Stoch Slowing", minval=1)                         // Slow Stochastic B: Slowing
SlowStoch_B_upper = input.float(70, "15m Stoch Upper Cross", minval=0, maxval=100)          // Slow Stochastic B: Upper Cross
SlowStoch_B_lower = input.float(30, "15m Stoch Lower Cross", minval=0, maxval=100)          // Slow Stochastic B: Lower Cross

//Nadaraya Watson Envelope Parameters (Entry criteria)                                      
NW_Bandwidth = input.float(30.0, "Bandwidth", minval=0)
NW_mult1 = input.float(2.5, title="Multiplier 1")
NW_mult2 = input.float(5.0, title="Multiplier 2")

//MA Cross Criteria
WMA_Length = input.int(100, "WMA Length (1h)")
HMA_Length = input.int(100, "HMA Length (1h)")
ma_tf = input.timeframe("60", title="MA & STOCH Timeframe")  // Default is 1h

contractionLookback = input.int(10, "Contraction Lookback", minval=1)
widthSmoothing = input.int(5, "Width Smoothing")

//On Screen Live TP and SL
// Reset when flat
var float StoredEntry = na
var float StoredSL = na
var float StoredTP = na
var line EntryLine = na
var line TPLine = na
var line SLLine = na

if (strategy.position_size == 0)
    StoredEntry := na
    StoredSL := na
    StoredTP := na
    line.delete(EntryLine)
    line.delete(TPLine)
    line.delete(SLLine)

// Trade Parameters
// sl_percent = input.float(10, "Trailing Stop Loss Trigger %", minval=1.0, step=0.1, maxval=100)
tp_1 = input.float(2, "Risk Reward Ratio Multiplier", minval = 0.1, step = 0.1, maxval = 10)

// Trade Parameter

// Timeframe definitions
tf_15m = "15"
tf_1h = "60"
tf_1d = "240"

// Indicator Definitions
src = close
tick_size = syminfo.mintick

// Kernel regression & Gaussian weight function approximation
gaussian_weight(x, NW_Bandwidth) => math.exp(-(math.pow(x, 2)/(NW_Bandwidth * NW_Bandwidth * 2)))

// Compute smoothed price estimate
weightedSum = 0.0
normFactor = 0.0
for i = 0 to 499
    w = gaussian_weight(i, NW_Bandwidth)
    weightedSum := weightedSum + src[i] * w
    normFactor := normFactor + w
NW_smoothedPrice = weightedSum / normFactor

// Calculate two envelope bands
stdDev = ta.stdev(close, int(NW_Bandwidth))
upperBand1 = ta.wma(NW_smoothedPrice + (stdDev * NW_mult1), SMA_A_Signal)
lowerBand1 = ta.wma(NW_smoothedPrice - (stdDev * NW_mult1), SMA_A_Signal)
upperBand2 = ta.wma(NW_smoothedPrice + (stdDev * NW_mult2), SMA_A_Signal)
lowerBand2 = ta.wma(NW_smoothedPrice - (stdDev * NW_mult2), SMA_A_Signal)

// 4 hour SMA (ended up not using this)
HMA1 = request.security(syminfo.tickerid, tf_15m, ta.hma(close, HMA_Length))
WMA1 = request.security(syminfo.tickerid, tf_15m, ta.wma(close, WMA_Length))
SMA1 = request.security(syminfo.tickerid, tf_15m, ta.sma(close, SMA_A_Length))
SMA_Daily = request.security(syminfo.tickerid, tf_1d, SMA1)

// 15m Slow Stochastic (B)
SlowStoch_B_K_raw = request.security(syminfo.tickerid, ma_tf,ta.stoch(close, high, low, SlowStoch_B_length))
SlowStoch_B_K = request.security(syminfo.tickerid, ma_tf,ta.sma(SlowStoch_B_K_raw, SlowStoch_B_sma))
SlowStoch_B_D = request.security(syminfo.tickerid, ma_tf,ta.sma(SlowStoch_B_K, SlowStoch_B_slow))

//Flicker removal
bandWidth = upperBand2 - upperBand1
smoothedWidth = ta.sma(bandWidth, widthSmoothing)
isContracting = smoothedWidth / smoothedWidth[contractionLookback] < 0.9


// Entry Conditions
// Long Conditions
long_condition = SlowStoch_B_D <= SlowStoch_B_lower and close < lowerBand1 and close > lowerBand2 and strategy.position_size[1] == 0 and isContracting

// Short Conditions
short_condition = SlowStoch_B_D >= SlowStoch_B_upper and close > upperBand1 and close < upperBand2 and strategy.position_size[1] == 0 and isContracting

// Entry Logic
if (long_condition)
    Band_Diff = math.abs(upperBand2 - upperBand1)
    sl_price = lowerBand2 - Band_Diff
    risk_value = float(close - sl_price)
    reward_value = float(risk_value * tp_1)
    tp_price = close + reward_value
    strategy.entry("Long", strategy.long)
    EntryPrice = strategy.opentrades.entry_price(strategy.opentrades)
    strategy.exit("Trailing Long", "Long", stop = sl_price, comment_loss = "SL " + str.tostring(sl_price), limit = tp_price, comment_profit = "TP " + str.tostring(close+reward_value))
    StoredEntry := strategy.opentrades.entry_price(0)
    StoredSL := sl_price
    StoredTP := tp_price


if (short_condition)
    Band_Diff = math.abs(upperBand2 - upperBand1)
    sl_price = upperBand2 + Band_Diff
    risk_value = float(sl_price - close)
    reward_value = float(risk_value * tp_1)
    tp_price = close - reward_value
    strategy.entry("Short", strategy.short)
    EntryPrice = strategy.opentrades.entry_price(strategy.opentrades)
    strategy.exit("Trailing Short", "Short", stop = sl_price,  comment_loss = "SL " + str.tostring(sl_price), limit = tp_price, comment_profit = "TP " + str.tostring(close-reward_value))
    StoredEntry := strategy.opentrades.entry_price(0)
    StoredSL := sl_price
    StoredTP := tp_price


if (strategy.opentrades > 0 and bar_index == strategy.opentrades.entry_bar_index(0))
    EntryLine := line.new(bar_index, StoredEntry, bar_index + 1, StoredEntry, extend=extend.right, color=color.yellow, width=2)
    TPLine := line.new(bar_index, StoredTP, bar_index + 1, StoredTP, extend=extend.right, color=color.orange, width=2)
    SLLine := line.new(bar_index, StoredSL, bar_index + 1, StoredSL, extend=extend.right, color=color.purple, width=2)

// Plotting
plot(upperBand1, color=color.red, linewidth = 3, title="Inner Envelope")
plot(lowerBand1, color=color.green, linewidth = 3, title="Inner Envelope")
plot(upperBand2, color=color.yellow, linewidth = 3, title="Outer Envelope")
plot(lowerBand2, color=color.yellow, linewidth = 3, title="Outer Envelope")
//plot(HMA1, color=color.fuchsia, linewidth=4, title="Hull Mooving Average")
//plot(WMA1, color=color.rgb(197, 197, 197), linewidth=4, title="Hull Mooving Average")

//Stochastic indicator
var color bgCol = color.rgb(0, 0, 0)
if SlowStoch_B_D < SlowStoch_B_lower
    bgCol := color.rgb(1, 37, 6, 25)
else if SlowStoch_B_D > SlowStoch_B_upper 
    bgCol := color.rgb(44, 1, 1, 25)
else 
    bgCol := color.rgb(20, 20, 20, 55)
// Apply background color
bgcolor(bgCol)

// End
